# 안심맵(AnsimMap) 환경변수 예시 — Vercel 대시보드에 동일 키 등록
# 민감 정보는 .AP-key.md 에서 관리하고 저장소에 커밋하지 않습니다.

# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxx
# service_role 키 — 백엔드(Route Handler) 전용. 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres

# 인증
JWT_SECRET=change-me-to-a-32+-char-random-secret

# 앱 URL (초대 링크/QR 생성용) — 운영은 Vercel 도메인
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth 2.0
# https://console.cloud.google.com 에서 OAuth 2.0 클라이언트 ID 생성 필요
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# 로컬 개발: true (토큰 검증 스킵) | Production: false (반드시 검증)
NEXT_PUBLIC_SKIP_TOKEN_VERIFY=true

# 카카오맵
KAKAO_MAP_API_KEY=
NEXT_PUBLIC_KAKAO_MAP_KEY=

# FCM (Firebase Admin SDK 서비스 계정 JSON 문자열)
FCM_SERVER_KEY=

# 카카오 알림톡 / NHN Cloud SMS
KAKAO_ALIMTALK_API_KEY=
SMS_API_KEY=
SMS_SENDER_NUMBER=

# 선택값
GEOCODING_CACHE_TTL=1800
