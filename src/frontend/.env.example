# 안심맵(AnsimMap) 환경변수 예시 — Vercel 대시보드에 동일 키 등록
# 민감 정보는 .AP-key.md 에서 관리하고 저장소에 커밋하지 않습니다.

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=

# 인증
JWT_SECRET=change-me-to-a-32+-char-random-secret

# 카카오맵
KAKAO_MAP_API_KEY=
NEXT_PUBLIC_KAKAO_MAP_KEY=

# FCM (Firebase Admin SDK 서비스 계정 JSON 문자열)
FCM_SERVER_KEY=

# 카카오 알림톡 / NHN Cloud SMS
KAKAO_ALIMTALK_API_KEY=
SMS_API_KEY=
SMS_SENDER_NUMBER=

# 선택값
GEOCODING_CACHE_TTL=1800
