{
  "name": "ansimmap-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "안심맵(AnsimMap) - 부모님 위치 확인 서비스 프론트엔드 (Next.js App Router)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "db:check": "node --env-file=.env.local scripts/check-supabase.mjs",
    "db:migrate": "node --env-file=.env.local scripts/apply-migrations.mjs",
    "db:seed-admin": "node --env-file=.env.local scripts/seed-admin.mjs",
    "deploy": "node --env-file=.env.local scripts/deploy-vercel.mjs"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "next": "^14.2.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "jest": "^29.7.0",
    "pg": "^8.13.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.3"
  }
}
